# Jira Server/Data Center configuration
JIRA_BASE_URL=https://jira.example.com
JIRA_USERNAME=your_username
JIRA_PASSWORD=your_password

# Optional: Personal Access Token (Jira 8.14+)
# If set, this takes priority over username/password
# JIRA_PAT=your_personal_access_token

# Optional: JQL filter to limit scope (default: fetches all accessible issues)
# JIRA_JQL=project in (PROJ1, PROJ2)

# Optional: Database file path (default: ./jira_data.db)
# DB_PATH=./jira_data.db

# Optional: Page size for API requests (default: 100)
# PAGE_SIZE=100
